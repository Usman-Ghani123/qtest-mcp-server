{
  "name": "qtest-mcp-server",
  "version": "0.1.0",
  "description": "Unofficial MCP server for qTest Manager — browse modules, fetch test cases, build test execution folders",
  "author": "Usman Ghani <ug.usman18@outlook.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/Usman-Ghani123/qtest-mcp-server.git"
  },
  "main": "dist/index.js",
  "bin": {
    "qtest-mcp-server": "dist/index.js"
  },
  "files": ["dist", "README.md", ".mcp.example.json"],
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "qtest",
    "mcp",
    "model-context-protocol",
    "qa",
    "testing"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.0",
    "dotenv": "^17.4.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.60.3",
    "@types/node": "^22.0.0",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.60.3"
  }
}
